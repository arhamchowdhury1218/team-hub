// This tells Prisma which database we're using (PostgreSQL)
// and where to find the connection string (from .env)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This tells Prisma which client language to generate
generator client {
  provider = "prisma-client-js"
}

// ─── User model ───────────────────────────────────────────────────────────────
// Each "model" becomes a table in your database
// Each field becomes a column in that table
model User {
  id           String   @id @default(cuid())   // unique ID, auto-generated
  email        String   @unique                 // must be unique per user
  password     String                           // hashed password (never plain text)
  name         String
  avatarUrl    String?                          // ? means this field is optional
  createdAt    DateTime @default(now())         // set automatically when record is created
  updatedAt    DateTime @updatedAt              // updated automatically on every save

  // Relations — a User can be a member of many workspaces
  memberships  WorkspaceMember[]
  // A User can own many goals
  ownedGoals   Goal[]            @relation("GoalOwner")
  // A User can be assigned many action items
  assignedItems ActionItem[]
  // A User can have many refresh tokens (one per device/session)
  refreshTokens RefreshToken[]
}

// ─── RefreshToken model ───────────────────────────────────────────────────────
// Stores the long-lived refresh tokens in the database
// so we can invalidate them on logout
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Workspace model ──────────────────────────────────────────────────────────
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  accentColor String   @default("#6366f1") // the accent color (a hex code)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members      WorkspaceMember[]
  goals        Goal[]
  announcements Announcement[]
  actionItems  ActionItem[]
}

// ─── WorkspaceMember model ────────────────────────────────────────────────────
// This is a "join table" — it links Users to Workspaces
// and stores the role (Admin or Member)
model WorkspaceMember {
  id          String   @id @default(cuid())
  role        String   @default("Member") // "Admin" or "Member"
  joinedAt    DateTime @default(now())

  // Foreign keys — these link to the actual User and Workspace records
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // A user can only be a member of the same workspace once
  @@unique([userId, workspaceId])
}

// ─── Goal model ───────────────────────────────────────────────────────────────
model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("active") // "active", "completed", "overdue"
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Which workspace this goal belongs to
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Who owns/is responsible for this goal
  ownerId     String
  owner       User      @relation("GoalOwner", fields: [ownerId], references: [id])

  // Relations
  milestones  Milestone[]
  actionItems ActionItem[]
}

// ─── Milestone model ──────────────────────────────────────────────────────────
// Milestones belong to Goals and track progress
model Milestone {
  id         String   @id @default(cuid())
  title      String
  progress   Int      @default(0) // 0 to 100 (percentage)
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  goalId     String
  goal       Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ─── Announcement model ───────────────────────────────────────────────────────
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   // rich text content stored as HTML string
  pinned      Boolean  @default(false) // whether it's pinned to the top
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── ActionItem model ─────────────────────────────────────────────────────────
model ActionItem {
  id          String   @id @default(cuid())
  title       String
  priority    String   @default("medium") // "low", "medium", "high"
  status      String   @default("todo")   // "todo", "in_progress", "done"
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Which workspace this item belongs to
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Optional: which goal this action item is linked to
  goalId      String?
  goal        Goal?     @relation(fields: [goalId], references: [id])

  // Who is assigned to complete this item
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
}